# Server
PORT=3000
NODE_ENV=development
# Origin allowed to call this API directly via CORS. The Next.js BFF talks to
# this API server-side (not subject to CORS), so this only matters for a
# direct-from-browser client (e.g. a future mobile web view).
CORS_ORIGIN=http://localhost:3001

# Postgres (RLS-enforced multi-tenant primary database)
DATABASE_URL=postgres://estatecore:password@localhost:5432/estatecore
DATABASE_POOL_MAX=10

# Redis (BullMQ queues, cache)
REDIS_URL=redis://localhost:6379

# Auth — self-issued RS256 JWTs (see apps/api/src/modules/auth). Generate a dev
# keypair with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Paste each PEM's contents verbatim, preserving line breaks (e.g. via `awk 1 ORS='\\n'`)
# or store as a single-line value with literal \n sequences depending on your env loader.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=https://auth.estatecore.app

# MFA TOTP secret encryption at rest (AES-256-GCM). Generate with: openssl rand -hex 32
MFA_ENCRYPTION_KEY=

# Paystack (Nigeria primary payment gateway)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_URL=https://api.estatecore.app/webhooks/paystack

# Tax
DEFAULT_VAT_PERCENT=7.5

# Outbound email (generic SMTP — works with SES, SendGrid, Mailgun, a local
# dev mailcatcher, etc.). Currently used for landing-page "Request access"
# notifications (see src/modules/inquiries and src/integrations/email). If
# SMTP_HOST is left unset, emails are logged instead of sent — safe for local
# dev without real credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@estatecore.app
